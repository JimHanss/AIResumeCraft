{
  "name": "@airesumecraft/editor",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "msw:init": "msw init public --save"
  },
  "dependencies": {
    "@airesumecraft/shared": "workspace:*",
    "@sentry/vue": "^10.63.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "lodash-es": "^4.18.1",
    "marked": "^18.0.5",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/vue3": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@types/lodash-es": "^4.17.12",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "storybook": "^10.4.6",
    "vite": "^8.1.3"
  }
