{
  "name": "airesumecraft",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0",
    "yarn": ">=4.0.0"
  },
  "scripts": {
    "dev": "yarn workspaces foreach -A -p -i --include @airesumecraft/editor --include @airesumecraft/portfolio run dev",
    "dev:editor": "yarn workspace @airesumecraft/editor dev",
    "dev:portfolio": "yarn workspace @airesumecraft/portfolio dev",
    "build": "yarn workspaces foreach -A -t run build",
    "build:editor": "yarn workspace @airesumecraft/editor build",
    "generate": "yarn workspace @airesumecraft/portfolio generate",
    "preview:editor": "yarn workspace @airesumecraft/editor preview",
    "preview:portfolio": "yarn workspace @airesumecraft/portfolio preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "yarn workspaces foreach -A run typecheck",
    "test": "yarn test:unit && yarn test:e2e",
    "test:unit": "yarn workspaces foreach -A run test:unit",
    "test:e2e": "playwright test",
    "storybook": "yarn workspace @airesumecraft/editor storybook",
    "build-storybook": "yarn workspace @airesumecraft/editor build-storybook",
    "lhci": "lhci autorun",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,mjs,cjs,json,md,css,yml,yaml}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
